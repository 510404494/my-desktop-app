{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "my-desktop-app",
  "version": "0.1.1",
  "identifier": "com.desktop-test.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "My Desktop App",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZENjU0N0EyRTYyMjMyQzgKUldUSU1pTG1va2RsYmZaVFBJOFIzSlRpWm5iNVkwN3FTTmIxWTRheHgvMlJUZlNRUitlSFJoSm4K",
      "endpoints": [
        "https://github.com/510404494/my-desktop-app/releases/latest/download/latest.json"
      ]
    }
  }
}
